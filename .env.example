# Copy to .env and fill in your values
SEPOLIA_RPC_URL=
PRIVATE_KEY=
ETHERSCAN_API_KEY=

# Used by admin/branch to pick the right deployment JSON
# 31337 = local Hardhat node, 11155111 = Sepolia
NEXT_PUBLIC_CHAIN_ID=31337

# Public RPC URL for read-only calls when MetaMask is not connected (admin app)
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
